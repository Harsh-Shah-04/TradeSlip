# Copy to .env for local development. Never commit .env.
# On Vercel: Project Settings → Environment Variables (Production).

SUPABASE_URL=https://xxxx.supabase.co
# Service-role key only — never use the anon key for this app, never put in frontend.
SUPABASE_KEY=your-service-role-key

# Only this Supabase Auth user may sign in (create the user in Supabase → Authentication → Users).
ALLOWED_EMAIL=father@example.com

# Local blank PDF (gitignored). On Vercel, leave unset and upload to Supabase instead.
TEMPLATE_PATH=assets/Airan_Blank_TradeSlip.pdf
# Private bucket object used when local TEMPLATE_PATH is missing:
TEMPLATE_STORAGE_PATH=templates/blank-trade-slip.pdf

# true/false, or leave unset (auto-true on Vercel/production HTTPS)
COOKIE_SECURE=
