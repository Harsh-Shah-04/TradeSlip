# Copy to .env for local development. Never commit .env.
# On Vercel: Project Settings → Environment Variables (Production).

SUPABASE_URL=https://xxxx.supabase.co
# Service-role key — server only (storage + DB). Never put in the browser.
SUPABASE_KEY=your-service-role-key
# Anon/public key — required for email/password login.
SUPABASE_ANON_KEY=your-anon-public-key

# First admin broker: auto-created in `brokers` on first login if missing.
# After migration, invite other brokers from /admin/users (do not share this for everyone).
ADMIN_BOOTSTRAP_EMAIL=father@example.com

# Local blank PDF (gitignored). On Vercel, leave unset and upload to Supabase instead.
TEMPLATE_PATH=assets/Airan_Blank_TradeSlip.pdf
# Private bucket object used when local TEMPLATE_PATH is missing:
TEMPLATE_STORAGE_PATH=templates/blank-trade-slip.pdf

# true/false, or leave unset (auto-true on Vercel/production HTTPS)
COOKIE_SECURE=

ENVIRONMENT=production
